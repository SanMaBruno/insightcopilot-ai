# Configuración general
APP_ENV=development
LOG_LEVEL=INFO

# IA — Proveedores
# LLM_MODE: mock | gemini | ollama | openai
LLM_MODE=mock
# EMBEDDING_MODE: mock | gemini | local | openai
# Nota: 'local' usa embeddings determinísticos (mismo comportamiento que mock).
# Ollama LLM + local embeddings = summary y narrativa ETL funcionan,
# pero RAG no tendrá recuperación semántica real.
EMBEDDING_MODE=mock

# Gemini (solo si LLM_MODE=gemini o EMBEDDING_MODE=gemini)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Ollama (solo si LLM_MODE=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (solo si LLM_MODE=openai o EMBEDDING_MODE=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ETL
ETL_MODE=manual

# Persistencia
DATABASE_URL=data/insightcopilot.db
UPLOAD_DIR=data/uploads
